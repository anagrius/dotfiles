#!/usr/bin/env bash
# Pre-push hook: trufflehog secret scan + git-lfs pre-push.
# stdin (ref list from git) is consumed once and replayed to each consumer.

remote="$1"
url="$2"

stdin_input="$(cat)"

# --- trufflehog secret scan -------------------------------------------------
# Arch's trufflehog-bin 3.95.2-1 ships a wrapper at /usr/bin/trufflehog that
# execs the wrong path (/usr/lib/trufflehog-bin/ vs the real /usr/lib/trufflehog/).
# Prefer the real binary when it's there.
if [ -x /usr/lib/trufflehog/trufflehog ]; then
  TRUFFLEHOG=/usr/lib/trufflehog/trufflehog
elif command -v trufflehog &>/dev/null; then
  TRUFFLEHOG=trufflehog
else
  TRUFFLEHOG=""
fi

if [ -z "$TRUFFLEHOG" ]; then
  echo "WARNING: trufflehog not installed, skipping secret scan"
  echo "  Install: yay -S trufflehog-bin"
else
  while read -r local_ref local_oid remote_ref remote_oid; do
    # Skip delete pushes
    if [ "$local_oid" = "0000000000000000000000000000000000000000" ]; then
      continue
    fi

    # For new branches, scan all commits not on remote
    if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
      range="$local_oid"
    else
      range="$remote_oid..$local_oid"
    fi

    echo "Scanning for secrets in $local_ref..."
    results=$("$TRUFFLEHOG" --no-update git "file://$(git rev-parse --show-toplevel)" --since-commit "$range" --fail 2>&1)
    exit_code=$?

    if [ $exit_code -ne 0 ]; then
      echo ""
      echo "PUSH BLOCKED: trufflehog found potential secrets!"
      echo ""
      echo "$results"
      echo ""
      echo "If this is a false positive, push with: git push --no-verify"
      exit 1
    fi
  done <<<"$stdin_input"
fi

# --- git-lfs pre-push -------------------------------------------------------
if command -v git-lfs &>/dev/null; then
  printf '%s\n' "$stdin_input" | git lfs pre-push "$remote" "$url" || exit $?
fi

exit 0
